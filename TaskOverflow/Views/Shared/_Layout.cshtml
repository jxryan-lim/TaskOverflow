<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TaskOverflow</title>

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />

    <!-- Animate.css -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/animations.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dark-mode.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
    <style>
        /* ── Profile avatar pill ── */
        .user-pill {
            transition: background .15s;
        }

            .user-pill:hover {
                background: rgba(0,0,0,.06);
            }

        .avatar-circle {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: linear-gradient(135deg, #1a73e8, #0d47a1);
            color: #fff;
            font-weight: 700;
            font-size: .85rem;
            flex-shrink: 0;
            user-select: none;
        }

        .avatar-circle-lg {
            width: 42px;
            height: 42px;
            font-size: 1.1rem;
        }

        /* ── Profile dropdown — moved to document root to fully escape stacking contexts ── */
        .profile-dropdown {
            min-width: 220px;
            border-radius: .75rem;
            border: 1px solid rgba(0,0,0,.08);
            position: fixed !important;
            z-index: 99999 !important;
        }

        /* Fix: table-responsive creates overflow:auto which clips the navbar dropdown */
        .table-responsive {
            overflow: visible !important;
        }

        /* Fix: navbar must sit above all page content */
        header, header .navbar {
            position: relative;
            z-index: 99998 !important;
        }

        .profile-dropdown .dropdown-item {
            border-radius: .4rem;
            margin: 1px 4px;
            padding: .45rem .75rem;
            font-size: .9rem;
        }

            .profile-dropdown .dropdown-item:hover {
                background: #f0f4ff;
            }

            .profile-dropdown .dropdown-item.text-danger:hover {
                background: #fff0f0;
            }

        /* dark-mode adjustments */
        [data-theme="dark"] .user-pill:hover {
            background: rgba(255,255,255,.1);
        }

        [data-theme="dark"] .profile-dropdown {
            background: #1e2130;
            border-color: rgba(255,255,255,.1);
        }

            [data-theme="dark"] .profile-dropdown .dropdown-item {
                color: #dde1f0;
            }

                [data-theme="dark"] .profile-dropdown .dropdown-item:hover {
                    background: rgba(255,255,255,.07);
                }

            [data-theme="dark"] .profile-dropdown hr {
                border-color: rgba(255,255,255,.1);
            }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-check2-square"></i> TaskOverflow
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Tasks" asp-action="Dashboard">
                                    <i class="bi bi-speedometer2"></i> Dashboard
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Tasks" asp-action="Index">
                                    <i class="bi bi-list-task"></i> My Tasks
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Home" asp-action="Index">
                                    <i class="bi bi-house"></i> Home
                                </a>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav align-items-center">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <!-- Profile dropdown -->
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle d-flex align-items-center gap-2 py-1 px-2 rounded-pill user-pill"
                                   href="#" id="profileDropdown" role="button"
                                   data-bs-toggle="dropdown" data-bs-auto-close="true"
                                   aria-expanded="false">
                                    <span class="avatar-circle">
                                        @(string.IsNullOrEmpty(User.Identity.Name) ? "?" : User.Identity.Name.Substring(0, 1).ToUpper())
                                    </span>
                                    <span class="d-none d-md-inline fw-medium">@User.Identity.Name</span>
                                    <i class="bi bi-chevron-down small"></i>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end profile-dropdown shadow" id="profileDropdownMenu" aria-labelledby="profileDropdown">
                                    <li class="dropdown-header px-3 pt-2 pb-1">
                                        <div class="d-flex align-items-center gap-2 mb-1">
                                            <span class="avatar-circle avatar-circle-lg">
                                                @(string.IsNullOrEmpty(User.Identity.Name) ? "?" : User.Identity.Name.Substring(0, 1).ToUpper())
                                            </span>
                                            <div>
                                                <div class="fw-semibold text-body">@User.Identity.Name</div>
                                                <div class="small text-muted">Logged in</div>
                                            </div>
                                        </div>
                                    </li>
                                    <li><hr class="dropdown-divider my-1"></li>
                                    <li>
                                        <a class="dropdown-item d-flex align-items-center gap-2" asp-controller="Account" asp-action="Profile">
                                            <i class="bi bi-person-badge text-primary"></i> My Profile
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item d-flex align-items-center gap-2" asp-controller="Account" asp-action="Settings">
                                            <i class="bi bi-gear text-secondary"></i> Settings
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider my-1"></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-block">
                                            <button type="submit" class="dropdown-item d-flex align-items-center gap-2 text-danger">
                                                <i class="bi bi-box-arrow-right"></i> Logout
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Register">
                                    <i class="bi bi-person-plus"></i> Register
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Login">
                                    <i class="bi bi-box-arrow-in-right"></i> Login
                                </a>
                            </li>
                        }

                        <!-- Theme Toggle Button -->
                        <li class="nav-item">
                            <button class="theme-toggle" onclick="toggleTheme()" title="Toggle theme">
                                <i class="bi bi-moon"></i>
                            </button>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container text-center">
            &copy; @DateTime.Now.Year - TaskOverflow
            <span class="mx-2">|</span>
            <i class="bi bi-github"></i>
            <i class="bi bi-heart-fill text-danger"></i>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/theme.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        // Use Popper fixed strategy so dropdown isn't clipped by any ancestor
        document.addEventListener('DOMContentLoaded', function () {
            const toggle = document.getElementById('profileDropdown');
            if (!toggle) return;
            new bootstrap.Dropdown(toggle, {
                popperConfig: function (defaultConfig) {
                    return Object.assign({}, defaultConfig, { strategy: 'fixed' });
                }
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>