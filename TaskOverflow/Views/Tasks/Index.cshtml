@model TaskListViewModel
@using TaskOverflow.Models
@{
    ViewData["Title"] = "My Tasks";
    var importResults = TempData["ImportResults"]?.ToString();
    var successMessage = TempData["SuccessMessage"]?.ToString();
    var errorMessage = TempData["ErrorMessage"]?.ToString();
}

<div class="container-fluid mt-4">
    <h2>My Tasks</h2>
    
    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @successMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @errorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    
    @if (!string.IsNullOrEmpty(importResults))
    {
        var results = System.Text.Json.JsonSerializer.Deserialize<ImportResult>(importResults);
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            <h5>Import Results</h5>
            <p>Successfully imported: @results.SuccessCount of @results.TotalRows tasks</p>
            @if (results.Errors.Any())
            {
                <p>Errors:</p>
                <ul>
                    @foreach (var error in results.Errors)
                    {
                        <li>@error</li>
                    }
                </ul>
            }
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    
    <!-- Search and Filter Bar -->
    <div class="row mb-3">
        <div class="col-md-12">
            <form method="get" class="row g-2">
                <div class="col-md-4">
                    <div class="input-group">
                        <input type="text" name="searchString" value="@Model.SearchString" 
                               class="form-control" placeholder="Search tasks...">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-search"></i> Search
                        </button>
                    </div>
                </div>
                
                <div class="col-md-2">
                    <select name="statusFilter" class="form-select" onchange="this.form.submit()">
                        <option value="All" selected="@(Model.StatusFilter == "All")">All Tasks</option>
                        <option value="Completed" selected="@(Model.StatusFilter == "Completed")">Completed</option>
                        <option value="Incomplete" selected="@(Model.StatusFilter == "Incomplete")">Incomplete</option>
                    </select>
                </div>
                
                <div class="col-md-2">
                    <select name="sortOrder" class="form-select" onchange="this.form.submit()">
                        <option value="asc" selected="@(Model.SortOrder == "asc")">Due Date ↑ (Earliest first)</option>
                        <option value="desc" selected="@(Model.SortOrder == "desc")">Due Date ↓ (Latest first)</option>
                    </select>
                </div>
                
                <div class="col-md-2">
                    <select name="pageSize" class="form-select" onchange="this.form.submit()">
                        @foreach (var size in Model.PageSizeOptions)
                        {
                            <option value="@size" selected="@(Model.PageSize == size)">@size per page</option>
                        }
                    </select>
                </div>
                
                <div class="col-md-2">
                    <div class="btn-group w-100">
                        <a asp-action="Create" class="btn btn-success">
                            <i class="bi bi-plus-circle"></i> Add Task
                        </a>
                        <button type="button" class="btn btn-primary dropdown-toggle dropdown-toggle-split" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-table"></i>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><h6 class="dropdown-header"><i class="bi bi-file-earmark-excel text-success"></i> Excel</h6></li>
                            <li>
                                <a asp-action="Export" asp-route-statusFilter="@Model.StatusFilter" asp-route-searchString="@Model.SearchString" class="dropdown-item">
                                    <i class="bi bi-download me-1"></i> Export Current View
                                </a>
                            </li>
                            <li>
                                <a href="#" class="dropdown-item" data-bs-toggle="modal" data-bs-target="#importModal">
                                    <i class="bi bi-upload me-1"></i> Import from Excel
                                </a>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <a asp-action="DownloadTemplate" class="dropdown-item text-muted">
                                    <i class="bi bi-file-earmark-arrow-down me-1"></i> Download Import Template
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Tasks Table -->
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th style="width: 5%">Status</th>
                    <th style="width: 40%">Description</th>
                    <th style="width: 15%">Category</th>
                    <th style="width: 15%">Due Date</th>
                    <th style="width: 15%">Created</th>
                    <th style="width: 10%">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Tasks.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center py-4">
                            <p class="text-muted mb-0">No tasks found. @(!string.IsNullOrEmpty(Model.SearchString) ? "Try a different search." : "Create your first task!")</p>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var task in Model.Tasks)
                    {
                        <tr class="task-item" style="animation-delay: @(Model.Tasks.IndexOf(task) * 0.1)s">
                            <tr class="@(task.IsCompleted ? "table-secondary" : "")">
                                <td class="align-middle text-center">
                                    <div class="form-check form-switch d-flex justify-content-center">
                                        <input class="form-check-input task-status" type="checkbox"
                                               data-task-id="@task.Id"
                                            @(task.IsCompleted ? "checked" : "")>
                                    </div>
                                </td>
                                <td class="align-middle">
                                    <span class="@(task.IsCompleted ? "text-decoration-line-through text-muted" : "")">
                                            @task.Description
                                    </span>
                                </td>
                                <td class="align-middle">
                                        @{
                                            var badgeClass = task.Category switch
                                            {
                                                CategoryType.Urgent => "bg-danger",
                                                CategoryType.Work => "bg-primary",
                                                CategoryType.Personal => "bg-info",
                                                _ => "bg-secondary"
                                            };
                                        }
                                    <span class="badge @badgeClass">@task.Category</span>
                                </td>
                                <td class="align-middle">
                                        @if (task.DueDate.HasValue)
                                        {
                                        <span class="@(task.DueDate.Value.Date < DateTime.Today && !task.IsCompleted ? "text-danger fw-bold" : "")">
                                                @task.DueDate.Value.ToString("MMM dd, yyyy")
                                        </span>
                                        }
                                        else
                                        {
                                        <span class="text-muted">No due date</span>
                                        }
                                </td>
                                <td class="align-middle">
                                    <small class="text-muted">@task.CreatedAt.ToString("MMM dd, yyyy")</small>
                                </td>
                                <td class="align-middle">
                                    <div class="btn-group btn-group-sm">
                                    <a asp-action="Edit" asp-route-id="@task.Id" class="btn btn-warning btn-sm"
                                       title="Edit with nested subtasks">
                                        <i class="bi bi-diagram-3"></i>
                                    </a>
                                        <button type="button" class="btn btn-danger"
                                                onclick="deleteTask(@task.Id, '@task.Description')">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { 
                        page = Model.CurrentPage - 1,
                        pageSize = Model.PageSize,
                        searchString = Model.SearchString,
                        statusFilter = Model.StatusFilter,
                        sortOrder = Model.SortOrder
                    })">Previous</a>
                </li>
                
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" href="@Url.Action("Index", new { 
                            page = i,
                            pageSize = Model.PageSize,
                            searchString = Model.SearchString,
                            statusFilter = Model.StatusFilter,
                            sortOrder = Model.SortOrder
                        })">@i</a>
                    </li>
                }
                
                <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { 
                        page = Model.CurrentPage + 1,
                        pageSize = Model.PageSize,
                        searchString = Model.SearchString,
                        statusFilter = Model.StatusFilter,
                        sortOrder = Model.SortOrder
                    })">Next</a>
                </li>
            </ul>
        </nav>
    }

    <!-- Summary -->
    <div class="row mt-3">
        <div class="col-md-12">
            <p class="text-muted">
                Showing @Model.Tasks.Count of @Model.TotalTasks tasks
            </p>
        </div>
    </div>
</div>

<!-- Import Modal -->
<div class="modal fade" id="importModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title"><i class="bi bi-file-earmark-excel me-2"></i>Import Tasks from Excel</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Import" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <!-- Info box -->
                    <div class="alert alert-info d-flex gap-2 align-items-start py-2">
                        <i class="bi bi-info-circle-fill mt-1 flex-shrink-0"></i>
                        <div>
                            <strong>Expected columns (row 1 = header, data from row 2):</strong>
                            <table class="table table-sm table-bordered mb-0 mt-2 bg-white">
                                <thead class="table-light">
                                    <tr><th>Column</th><th>Name</th><th>Required?</th><th>Notes</th></tr>
                                </thead>
                                <tbody>
                                    <tr><td>A</td><td>Description</td><td><span class="badge bg-danger">Required</span></td><td>Max 500 chars</td></tr>
                                    <tr><td>B</td><td>Category</td><td><span class="badge bg-danger">Required</span></td><td>Work | Personal | Urgent</td></tr>
                                    <tr><td>C</td><td>Due Date</td><td><span class="badge bg-secondary">Optional</span></td><td>yyyy-MM-dd</td></tr>
                                    <tr><td>D</td><td>Start Date</td><td><span class="badge bg-secondary">Optional</span></td><td>yyyy-MM-dd</td></tr>
                                    <tr><td>E</td><td>End Date</td><td><span class="badge bg-secondary">Optional</span></td><td>yyyy-MM-dd</td></tr>
                                    <tr><td>F</td><td>Status</td><td><span class="badge bg-secondary">Optional</span></td><td>Completed or Incomplete (default: Incomplete)</td></tr>
                                </tbody>
                            </table>
                            <div class="mt-2">
                                <a asp-action="DownloadTemplate" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-file-earmark-arrow-down me-1"></i>Download Template
                                </a>
                                <small class="text-muted ms-2">The exported file also contains a ready-to-use template sheet.</small>
                            </div>
                        </div>
                    </div>

                    <!-- File picker -->
                    <div class="mb-3">
                        <label for="file" class="form-label fw-semibold">Select Excel file (.xlsx)</label>
                        <input type="file" class="form-control" id="file" name="file" accept=".xlsx,.xls" required>
                        <div class="form-text">Legacy exports (Description | Due Date | Category | Status) are also accepted.</div>
                    </div>

                    <!-- Drag-drop hint -->
                    <div id="dropZone" class="border border-2 border-dashed rounded p-4 text-center text-muted" style="cursor:pointer; transition: background .2s;"
                         onclick="document.getElementById('file').click()">
                        <i class="bi bi-cloud-upload fs-3 d-block mb-1"></i>
                        <span>or drag &amp; drop your file here</span>
                    </div>
                    <div id="fileNameDisplay" class="mt-2 text-success fw-semibold d-none"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-upload me-1"></i>Import Tasks
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete the task: <strong id="taskDescription"></strong>?</p>
            </div>
            <div class="modal-footer">
                <form id="deleteForm" method="post" asp-action="Delete">
                    <input type="hidden" name="id" id="taskId" />
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Handle status toggle
        document.querySelectorAll('.task-status').forEach(checkbox => {
            checkbox.addEventListener('change', async function() {
                const taskId = this.dataset.taskId;
                try {
                    const response = await fetch(`/Tasks/ToggleStatus/${taskId}`, {
                        method: 'POST',
                        headers: {
                            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                        }
                    });
                    
                    if (response.ok) {
                        location.reload();
                    }
                } catch (error) {
                    console.error('Error toggling task status:', error);
                }
            });
        });

        // Handle delete
        function deleteTask(id, description) {
            document.getElementById('taskId').value = id;
            document.getElementById('taskDescription').textContent = description;
            var deleteModal = new bootstrap.Modal(document.getElementById('deleteModal'));
            deleteModal.show();
        }

        // Drag-and-drop file upload on import modal
        const dropZone = document.getElementById('dropZone');
        const fileInput = document.getElementById('file');
        const fileNameDisplay = document.getElementById('fileNameDisplay');

        if (dropZone && fileInput) {
            fileInput.addEventListener('change', () => {
                if (fileInput.files.length) showFileName(fileInput.files[0].name);
            });

            dropZone.addEventListener('dragover', e => {
                e.preventDefault();
                dropZone.style.background = '#e8f0fe';
            });
            dropZone.addEventListener('dragleave', () => dropZone.style.background = '');
            dropZone.addEventListener('drop', e => {
                e.preventDefault();
                dropZone.style.background = '';
                const dt = new DataTransfer();
                dt.items.add(e.dataTransfer.files[0]);
                fileInput.files = dt.files;
                showFileName(e.dataTransfer.files[0].name);
            });
        }

        function showFileName(name) {
            fileNameDisplay.textContent = '✓ ' + name;
            fileNameDisplay.classList.remove('d-none');
        }
    </script>
}