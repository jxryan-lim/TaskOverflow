@model TaskListViewModel
@using TaskOverflow.Models
@{
    ViewData["Title"] = "My Tasks";
    var importResults = TempData["ImportResults"]?.ToString();
    var successMessage = TempData["SuccessMessage"]?.ToString();
    var errorMessage = TempData["ErrorMessage"]?.ToString();
}

<div class="container-fluid mt-4">
    <h2>My Tasks</h2>
    
    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @successMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @errorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    
    @if (!string.IsNullOrEmpty(importResults))
    {
        var results = System.Text.Json.JsonSerializer.Deserialize<ImportResult>(importResults);
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            <h5>Import Results</h5>
            <p>Successfully imported: @results.SuccessCount of @results.TotalRows tasks</p>
            @if (results.Errors.Any())
            {
                <p>Errors:</p>
                <ul>
                    @foreach (var error in results.Errors)
                    {
                        <li>@error</li>
                    }
                </ul>
            }
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    
    <!-- Search and Filter Bar -->
    <div class="row mb-3">
        <div class="col-md-12">
            <form method="get" class="row g-2">
                <div class="col-md-4">
                    <div class="input-group">
                        <input type="text" name="searchString" value="@Model.SearchString" 
                               class="form-control" placeholder="Search tasks...">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-search"></i> Search
                        </button>
                    </div>
                </div>
                
                <div class="col-md-2">
                    <select name="statusFilter" class="form-select" onchange="this.form.submit()">
                        <option value="All" selected="@(Model.StatusFilter == "All")">All Tasks</option>
                        <option value="Completed" selected="@(Model.StatusFilter == "Completed")">Completed</option>
                        <option value="Incomplete" selected="@(Model.StatusFilter == "Incomplete")">Incomplete</option>
                    </select>
                </div>
                
                <div class="col-md-2">
                    <select name="sortOrder" class="form-select" onchange="this.form.submit()">
                        <option value="asc" selected="@(Model.SortOrder == "asc")">Due Date ↑ (Earliest first)</option>
                        <option value="desc" selected="@(Model.SortOrder == "desc")">Due Date ↓ (Latest first)</option>
                    </select>
                </div>
                
                <div class="col-md-2">
                    <select name="pageSize" class="form-select" onchange="this.form.submit()">
                        @foreach (var size in Model.PageSizeOptions)
                        {
                            <option value="@size" selected="@(Model.PageSize == size)">@size per page</option>
                        }
                    </select>
                </div>
                
                <div class="col-md-2">
                    <div class="btn-group w-100">
                        <a asp-action="Create" class="btn btn-success">
                            <i class="bi bi-plus-circle"></i> Add Task
                        </a>
                        <button type="button" class="btn btn-primary dropdown-toggle" data-bs-toggle="dropdown">
                            <i class="bi bi-download"></i>
                        </button>
                        <ul class="dropdown-menu">
                            <li><a asp-action="Export" class="dropdown-item">Export to Excel</a></li>
                            <li><a href="#" class="dropdown-item" data-bs-toggle="modal" data-bs-target="#importModal">Import from Excel</a></li>
                        </ul>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Tasks Table -->
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th style="width: 5%">Status</th>
                    <th style="width: 40%">Description</th>
                    <th style="width: 15%">Category</th>
                    <th style="width: 15%">Due Date</th>
                    <th style="width: 15%">Created</th>
                    <th style="width: 10%">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Tasks.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center py-4">
                            <p class="text-muted mb-0">No tasks found. @(!string.IsNullOrEmpty(Model.SearchString) ? "Try a different search." : "Create your first task!")</p>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var task in Model.Tasks)
                    {
                        <tr class="task-item" style="animation-delay: @(Model.Tasks.IndexOf(task) * 0.1)s">
                            <tr class="@(task.IsCompleted ? "table-secondary" : "")">
                                <td class="align-middle text-center">
                                    <div class="form-check form-switch d-flex justify-content-center">
                                        <input class="form-check-input task-status" type="checkbox"
                                               data-task-id="@task.Id"
                                            @(task.IsCompleted ? "checked" : "")>
                                    </div>
                                </td>
                                <td class="align-middle">
                                    <span class="@(task.IsCompleted ? "text-decoration-line-through text-muted" : "")">
                                            @task.Description
                                    </span>
                                </td>
                                <td class="align-middle">
                                        @{
                                            var badgeClass = task.Category switch
                                            {
                                                CategoryType.Urgent => "bg-danger",
                                                CategoryType.Work => "bg-primary",
                                                CategoryType.Personal => "bg-info",
                                                _ => "bg-secondary"
                                            };
                                        }
                                    <span class="badge @badgeClass">@task.Category</span>
                                </td>
                                <td class="align-middle">
                                        @if (task.DueDate.HasValue)
                                        {
                                        <span class="@(task.DueDate.Value.Date < DateTime.Today && !task.IsCompleted ? "text-danger fw-bold" : "")">
                                                @task.DueDate.Value.ToString("MMM dd, yyyy")
                                        </span>
                                        }
                                        else
                                        {
                                        <span class="text-muted">No due date</span>
                                        }
                                </td>
                                <td class="align-middle">
                                    <small class="text-muted">@task.CreatedAt.ToString("MMM dd, yyyy")</small>
                                </td>
                                <td class="align-middle">
                                    <div class="btn-group btn-group-sm">
                                    <a asp-action="Edit" asp-route-id="@task.Id" class="btn btn-warning btn-sm"
                                       title="Edit with nested subtasks">
                                        <i class="bi bi-diagram-3"></i>
                                    </a>
                                        <button type="button" class="btn btn-danger"
                                                onclick="deleteTask(@task.Id, '@task.Description')">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { 
                        page = Model.CurrentPage - 1,
                        pageSize = Model.PageSize,
                        searchString = Model.SearchString,
                        statusFilter = Model.StatusFilter,
                        sortOrder = Model.SortOrder
                    })">Previous</a>
                </li>
                
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" href="@Url.Action("Index", new { 
                            page = i,
                            pageSize = Model.PageSize,
                            searchString = Model.SearchString,
                            statusFilter = Model.StatusFilter,
                            sortOrder = Model.SortOrder
                        })">@i</a>
                    </li>
                }
                
                <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { 
                        page = Model.CurrentPage + 1,
                        pageSize = Model.PageSize,
                        searchString = Model.SearchString,
                        statusFilter = Model.StatusFilter,
                        sortOrder = Model.SortOrder
                    })">Next</a>
                </li>
            </ul>
        </nav>
    }

    <!-- Summary -->
    <div class="row mt-3">
        <div class="col-md-12">
            <p class="text-muted">
                Showing @Model.Tasks.Count of @Model.TotalTasks tasks
            </p>
        </div>
    </div>
</div>

<!-- Import Modal -->
<div class="modal fade" id="importModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Import Tasks from Excel</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Import" method="post" enctype="multipart/form-data">
                <div class="modal-body">
                    <p>Download a <a href="/templates/task-import-template.xlsx" class="text-primary">sample template</a></p>
                    <p>The Excel file should have columns: Description, Due Date, Category, Status</p>
                    <div class="mb-3">
                        <label for="file" class="form-label">Select Excel file</label>
                        <input type="file" class="form-control" id="file" name="file" accept=".xlsx,.xls" required>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Import</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete the task: <strong id="taskDescription"></strong>?</p>
            </div>
            <div class="modal-footer">
                <form id="deleteForm" method="post" asp-action="Delete">
                    <input type="hidden" name="id" id="taskId" />
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Handle status toggle
        document.querySelectorAll('.task-status').forEach(checkbox => {
            checkbox.addEventListener('change', async function() {
                const taskId = this.dataset.taskId;
                try {
                    const response = await fetch(`/Tasks/ToggleStatus/${taskId}`, {
                        method: 'POST',
                        headers: {
                            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                        }
                    });
                    
                    if (response.ok) {
                        location.reload();
                    }
                } catch (error) {
                    console.error('Error toggling task status:', error);
                }
            });
        });

        // Handle delete
        function deleteTask(id, description) {
            document.getElementById('taskId').value = id;
            document.getElementById('taskDescription').textContent = description;
            var deleteModal = new bootstrap.Modal(document.getElementById('deleteModal'));
            deleteModal.show();
        }
    </script>
}